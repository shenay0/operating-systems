#include <fcntl.h>
#include <stdlib.h>
#include <unistd.h>
#include <err.h>

int main(void){
    int fd1, fd2;

    if((fd1=open("/etc/passwd", O_RDONLY)) == -1){
        err(1, "Error while opening file to read");
    }

    if((fd2=open("passwd", O_CREAT | O_TRUNC | O_WRONLY, 0644)) == -1){
        close(fd1);
        err(1, "Error while opening file to write.");
    }

    char buff[4026];

    int size;

    while((size=read(fd1, buff,sizeof(buff))) > 0){
        for(int i = 0; i < size; i++){
            if(buff[i] == ':'){
                buff[i]='?';
            }
        }


        if(write(fd2, buff,size) == -1){
            //close both
            err(1, "Error while writing");
        }
    }

    close(fd1);
    close(fd2);
    exit(0);
}
