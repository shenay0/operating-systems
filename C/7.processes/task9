#include <stdlib.h>
#include <unistd.h>
#include <sys/wait.h>
#include <fcntl.h>
#include <err.h>

int main(int argc, char* args[]){
    if(argc != 2){
        errx(1, "Invalid arguments");
    }

    int fd = open(args[1], O_RDWR | O_CREAT | O_TRUNC , 0644);
    if(fd == -1) {
        err(1,"Couldnt open file");
    }

    int child1 = fork();

    if(child1 == -1){
        err(1, "Couldnt fork child1");
    }

    if(child1 == 0){
        if(write(fd, "foo", 3) == -1){
            err(1, "Couldnt write");
        }

        close(fd);
        exit(0);
    }

    int status;

    int pid1 = wait(&status);
    if(pid1 == -1){
        err(1,"Couldnt wait for child1");
    }

    int child2 = fork();

    if(child2 == -1){
        err(1,"Coudlnt fork child2");
    }

    if(child2 == 0){
        if(write(fd, "bar", 3) == -1){
            err(1, "Couldnt write to file");
        }

        close(fd);
        exit(0);
    }

    int pid2 = wait(&status);

    if(pid2 == -1) {
        err(1, "Couldnt wait for child2");
    }

    close(fd);
    exit(0);
}
