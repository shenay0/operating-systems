#include <stdlib.h>
#include <unistd.h>
#include <err.h>
#include <sys/wait.h>
#include <string.h>

int main(int argc, char* args[]){
    if(argc != 2){
        errx(1,"Invalid arguments");
    }

    pid_t pid = fork();
    if(pid == -1){
        err(1,"Couldnt fork");
    }

    int status;

    if(pid == 0){
        if(execlp(args[1], args[1], (char*) NULL)==-1){
            err(1,"Couldnt execute");
        }
    }

    pid_t child_pid = wait(&status);
    if(!WIFEXITED(status)){
        errx(1,"Program was killed");
    }
    else if(WEXITSTATUS(status) != 0){
        errx(1,"Couldnt execute command.");
    }
    else{
        write(1, args[1], strlen(args[1]));
    }

    exit(0);
}
