#!/bin/bash
#Даден е текстов файл с име philip-j-fry.txt. Напишете shell script и/или серия от коман-
#ди, които извеждат броя редове, съдържащи поне една четна цифра и несъдържащи малка латинска
#буква от a до w.
#Примерно съдържание на файла:
#123abv123
#123zz123
#MMU_2.4
#Примерен изход:
#Броят на търсените редовете е 2


grep '[02468]' philip-j-fry.txt | grep -v '[a-w]' philip-j-fry.txt | wc -l
